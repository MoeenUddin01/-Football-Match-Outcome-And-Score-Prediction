{
  "outputDirectory": ".next",
  "functions": {
    "api/index.py": {
      "maxDuration": 30,
      "excludeFiles": "{node_modules/**,.next/**,.vercel/**,app/**,components/**,lib/**,public/**,__tests__/**,api/src/data/**,api/data/raw/former_names.csv,api/data/raw/shootouts.csv}"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" }
  ]
}
